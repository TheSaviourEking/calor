# .env.example

# DATABASE
# Required. PostgreSQL connection string.
DATABASE_URL="postgresql://calor:calor123@localhost:5432/calor?schema=public"

# AUTHENTICATION
# Required. Minimum 32 characters random string for signing JWT tokens.
# Generate via: openssl rand -base64 32
JWT_SECRET="your_jwt_secret_placeholder_change_in_production"

# STRIPE
# Required. Get from dashboard.stripe.com/development/apikeys
STRIPE_SECRET_KEY="sk_test_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_placeholder"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_placeholder"

# COINBASE COMMERCE
# Required. Get from commerce.coinbase.com/settings/security
COINBASE_COMMERCE_API_KEY="your-coinbase-api-key-placeholder"
COINBASE_WEBHOOK_SECRET="your-coinbase-webhook-secret-placeholder"

# EMAIL (RESEND)
# Required. Get from resend.com/api-keys
RESEND_API_KEY="re_placeholder"

# CRON JOBS
CRON_SECRET="your_cron_secret_placeholder"

# GOOGLE (PLACES & OAUTH)
GOOGLE_PLACES_API_KEY="your_google_places_api_key_placeholder"
GOOGLE_CLIENT_ID="your_google_client_id_placeholder"
GOOGLE_CLIENT_SECRET="your_google_client_secret_placeholder"

# APPLE (OAUTH)
APPLE_CLIENT_ID="your_apple_client_id_placeholder"
APPLE_TEAM_ID="your_apple_team_id_placeholder"
APPLE_KEY_ID="your_apple_key_id_placeholder"
APPLE_PRIVATE_KEY="your_apple_private_key_placeholder"

# WEBSOCKET SERVICES
# In production (Fly.io), set to your deployed service URLs
NEXT_PUBLIC_SUPPORT_CHAT_URL=""   # e.g., https://calor-support-chat.fly.dev
NEXT_PUBLIC_LIVE_STREAM_URL=""    # e.g., https://calor-live-stream.fly.dev

# LIVEKIT (Video Streaming)
# For local dev: defaults to devkey/secret/ws://localhost:7880
# For production: use LiveKit Cloud (livekit.io)
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""
NEXT_PUBLIC_LIVEKIT_URL=""        # e.g., wss://your-project.livekit.cloud

# Cloudflare R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=calor-uploads
R2_PUBLIC_URL=

# Sentry (optional - error monitoring)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Rate Limiting (optional - Redis for multi-instance, falls back to in-memory)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Exchange Rates (optional - OpenExchangeRates.org)
OPENEXCHANGERATES_APP_ID=

# APPLICATION
# Required. The base URL of the application.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
