# ============================================================================
# CALŌR — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values.
# Variables marked [REQUIRED] must be set for the app to start.
# Variables marked [OPTIONAL] have defaults or graceful fallbacks.
# ============================================================================

# ── DATABASE ────────────────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string.
# Free: Neon (neon.tech) — 0.5GB free tier
DATABASE_URL="postgresql://calor:calor123@localhost:5432/calor?schema=public"

# ── APPLICATION ─────────────────────────────────────────────────────────────
# [REQUIRED] Base URL of your deployed app. Used for OAuth redirects, emails, etc.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ── AUTHENTICATION ──────────────────────────────────────────────────────────
# [REQUIRED] JWT signing secret. Minimum 32 characters.
# Generate: openssl rand -base64 32
JWT_SECRET=""

# ── STRIPE (Payments + Subscriptions) ──────────────────────────────────────
# [REQUIRED] Get from: dashboard.stripe.com/apikeys
# Free: Stripe test mode is free. Live mode charges per transaction.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── COINBASE COMMERCE (Crypto Payments) ────────────────────────────────────
# [REQUIRED] Get from: commerce.coinbase.com → Settings → Security
COINBASE_COMMERCE_API_KEY=""
COINBASE_WEBHOOK_SECRET=""

# ── EMAIL (Resend) ─────────────────────────────────────────────────────────
# [REQUIRED] Get from: resend.com/api-keys
# Free: 100 emails/day, 3,000/month on free tier
RESEND_API_KEY="re_..."

# ── CRON JOBS ──────────────────────────────────────────────────────────────
# [REQUIRED] Secret for authenticating cron job endpoints.
# Generate: openssl rand -hex 16
CRON_SECRET=""

# ── GOOGLE (OAuth + Places) ────────────────────────────────────────────────
# [OPTIONAL] Google OAuth login. Get from: console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# [OPTIONAL] Address autocomplete. Get from: console.cloud.google.com → APIs
GOOGLE_PLACES_API_KEY=""

# ── APPLE (OAuth) ──────────────────────────────────────────────────────────
# [OPTIONAL] Apple Sign In. Get from: developer.apple.com
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""

# ── LIVEKIT (Video Streaming) ──────────────────────────────────────────────
# [OPTIONAL] Defaults to local dev values (devkey/secret/ws://localhost:7880)
# Free: LiveKit Cloud (livekit.io) — 50GB bandwidth/month free
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""
NEXT_PUBLIC_LIVEKIT_URL=""
# Local dev: ws://localhost:7880
# Production: wss://your-project.livekit.cloud

# ── WEBSOCKET SERVICES ────────────────────────────────────────────────────
# [OPTIONAL] URLs for mini-services. Defaults to local Caddy proxy routing.
# In production, set to your deployed service URLs.
NEXT_PUBLIC_SUPPORT_CHAT_URL=""
# Local: /?XTransformPort=3031
# Production: https://calor-support-chat.your-host.com

NEXT_PUBLIC_LIVE_STREAM_URL=""
# Local: /?XTransformPort=3032
# Production: https://calor-live-stream.your-host.com

# [OPTIONAL] Comma-separated allowed origins for Socket.io CORS.
SOCKET_IO_ORIGINS="http://localhost:3000,https://calorco.com"

# ── CLOUDFLARE R2 (Image Storage) ─────────────────────────────────────────
# [OPTIONAL] Required for image uploads. Without these, upload returns 503.
# Free: Cloudflare R2 — 10GB storage, 1M reads/month free
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="calor-uploads"
R2_PUBLIC_URL=""
# Format: https://pub-{accountId}.r2.dev or custom domain

# ── SENTRY (Error Monitoring) ──────────────────────────────────────────────
# [OPTIONAL] Get from: sentry.io → Project Settings → Client Keys
# Free: 5,000 errors/month, 10,000 transactions/month
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
# Auth token only needed for source map uploads during build

# ── UPSTASH REDIS (Rate Limiting) ─────────────────────────────────────────
# [OPTIONAL] For distributed rate limiting across multiple instances.
# Falls back to in-memory if not configured.
# Free: Upstash (upstash.com) — 10,000 commands/day
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── EXCHANGE RATES ─────────────────────────────────────────────────────────
# [OPTIONAL] For dynamic currency conversion. Falls back to hardcoded rates.
# Free: OpenExchangeRates (openexchangerates.org) — 1,000 requests/month
OPENEXCHANGERATES_APP_ID=""
